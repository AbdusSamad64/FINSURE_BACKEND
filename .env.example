# Authentication / JWT
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# FINSURE Assistant (RAG chatbot)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
# Optional overrides:
#   CHATBOT_PROVIDER=groq | openai | gemini   (default: groq)
#   CHATBOT_MODEL=llama-3.1-8b-instant
#   OPENAI_API_KEY=
#   GEMINI_API_KEY=

# Apache Superset (embedded dashboards)
# Superset runs in Docker (see superset/ folder). These credentials are used
# server-to-server from FastAPI to mint short-lived "guest tokens" that the
# frontend then uses to render dashboards with per-user row-level security.
# `SUPERSET_URL` is the browser-facing URL (iframe domain).
SUPERSET_URL=http://localhost:8088
# `SUPERSET_INTERNAL_URL` is what the backend container uses to reach Superset
# over the Docker network. In the all-in-one `docker-compose.yml`, this should
# be the Superset service name:
SUPERSET_INTERNAL_URL=http://superset:8088
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=change-me
# Set after enabling "Embed dashboard" on a dashboard in the Superset UI.
SUPERSET_DASHBOARD_UUID=
