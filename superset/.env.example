# Apache Superset stack — environment template.
# Copy to `.env` (same folder) and fill in real values before `docker compose up`.

# Random 50-char string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=change-me-to-a-long-random-string

# Admin account created at first boot. You'll log in to http://localhost:8088 with these.
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_EMAIL=admin@finsure.local
SUPERSET_ADMIN_PASSWORD=change-me
